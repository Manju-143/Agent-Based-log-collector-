# PKSL runtime (example)
PKSL_SERVER_HOST=127.0.0.1
PKSL_SERVER_PORT=9000

# AES key (example only; replace in real runs)
PKSL_AES_KEY=CHANGE_ME_BASE64_32_BYTES

# OpenSearch (example)
PKSL_OS_ENABLED=1
PKSL_OS_HOST=localhost
PKSL_OS_PORT=9200
PKSL_OS_INDEX=pksl-verified-logs
PKSL_OS_USER=admin
PKSL_OS_PASS=CHANGE_ME
PKSL_OS_SSL=1
PKSL_OS_VERIFY_CERTS=0